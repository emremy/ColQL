{
  "name": "memql",
  "version": "0.0.2",
  "description": "TypeScript-first in-memory query and compact columnar storage engine",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --watch",
    "test": "vitest run",
    "benchmark:memory": "node --expose-gc benchmarks/memory.mjs",
    "benchmark:query": "node benchmarks/query.mjs",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "query",
    "in-memory",
    "typescript",
    "columnar",
    "storage",
    "typed-array"
  ],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/emremy/memql/issues"
  },
  "homepage": "https://github.com/emremy/memql#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  }
}
