{
  "name": "@colql/example-fastify-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/server.ts",
    "dev:1m": "COLQL_EXAMPLE_SEED_SIZE=1000000 tsx src/server.ts",
