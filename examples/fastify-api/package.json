  },
  "dependencies": {
    "fastify": "^5.6.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.20.6",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
